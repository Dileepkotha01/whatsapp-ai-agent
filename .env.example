# ══════════════════════════════════════════════════════════════════
#  Ekaralu WhatsApp Agent — Environment Variables
#  Copy this file to .env and fill in your values.
#  The agent can run on a SEPARATE server from the Ekaralu backend.
# ══════════════════════════════════════════════════════════════════

# ── Anthropic (Claude AI) ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Agent Server Port ──────────────────────────────────────────────
# The port this WhatsApp agent's dashboard runs on.
PORT=47821

# ── WhatsApp Admin / Verifier Numbers ─────────────────────────────
# Without + or spaces. Format: countrycode + number
# e.g. India +91 95025 09455 → 919502527272
ADMIN_WHATSAPP_NUMBER=""
VERIFIER_WHATSAPP_NUMBER=""   # Can be the same as ADMIN

# ── Ekaralu Backend API (runs on api.ekaralu.com) ─────────────────
# Base URL of the Ekaralu backend. No trailing slash.
BACKEND_API_URL=https://api.ekaralu.com

# ── Ekaralu Frontend URL ───────────────────────────────────────────
# Used to build the live property link sent to the user.
FRONTEND_URL=https://ekaralu.com
NODE_ENV=production
DEPLOYMENT_URL=""

# ── Bot Upload Token ───────────────────────────────────────────────
# Must exactly match the token in backend configuration
BOT_UPLOAD_TOKEN=ekaralu_secure_upload_999!

# ── Admin Panel Credentials (Dashboard) ────────────────────────────
ADMIN_LOGIN_EMAIL=admin@ekaralu.com
ADMIN_LOGIN_PASSWORD=ChangeMeNow!
SESSION_SECRET=create_a_strong_random_secret_here

# ── Deployment Configuration ───────────────────────────────────────
# The domain where this agent dashboard is hosted
DEPLOYMENT_URL=""
NODE_ENV=production

# ── Hostinger MySQL Database ───────────────────────────────────────
# IMPORTANT: Whitelist this agent server's public IP in Hostinger
# Control Panel → Databases → Remote MySQL before deploying.
DB_HOST=""
DB_PORT=3306
DB_USER=""
DB_PASSWORD=your_db_password_here
DB_NAME=""
